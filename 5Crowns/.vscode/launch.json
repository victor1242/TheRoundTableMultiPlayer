{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug 5Crowns (Chrome localhost)",
            "type": "pwa-chrome",
            "request": "launch",
            "url": "http://localhost:5500/index.html",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "Start Local Static Server"
        },
        {
            "name": "Debug index.html (Edge via localhost)",
            "type": "pwa-msedge",
            "request": "launch",
            "url": "http://localhost:5500/index.html",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "Start Local Static Server"
        },
        {
            "name": "Debug index.html (Edge file)",
            "type": "pwa-msedge",
            "request": "launch",
            "file": "${workspaceFolder}/index.html",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Debug index.html (Chrome)",
            "type": "pwa-chrome",
            "request": "launch",
            "file": "${workspaceFolder}/index.html",
            "webRoot": "${workspaceFolder}"
        },
        {
            "name": "Debug Current JS File (Node)",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "skipFiles": [
                "<node_internals>/**"
            ]
        }
    ]
}